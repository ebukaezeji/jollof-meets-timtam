<header class="w-full bg-white border-b border-gray-200 fixed top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-xl font-bold tracking-tight text-black">Jollof</span>
      <span class="text-xl font-bold tracking-tight text-black">meets</span>
      <span class="text-xl font-bold tracking-tight text-black">TimTam</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a href="#about" class="text-sm font-medium text-charcoal hover:text-emerald transition-colors no-underline">About</a>
      <a href="#events" class="text-sm font-medium text-charcoal hover:text-emerald transition-colors no-underline">Events</a>
      <a href="#join" class="text-sm font-medium bg-emerald text-white px-5 py-2 rounded-full hover:bg-emerald-dark transition-colors no-underline">Join us</a>
    </nav>
    <button id="mobile-menu-btn" class="md:hidden p-2 text-charcoal" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18"/>
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-6 py-4 space-y-3">
      <a href="#about" class="block text-sm font-medium text-charcoal hover:text-emerald no-underline">About</a>
      <a href="#events" class="block text-sm font-medium text-charcoal hover:text-emerald no-underline">Events</a>
      <a href="#join" class="block text-sm font-medium text-emerald no-underline">Join us</a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    if (menu) {
      menu.classList.toggle('hidden');
    }
  });
</script>
