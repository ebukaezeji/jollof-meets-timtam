<section id="join" class="py-16 md:py-24 bg-surface-container-lowest">
<div class="max-w-3xl mx-auto px-5 md:px-16">
<div class="bg-white p-8 md:p-12 rounded-lg border border-outline-variant shadow-xl relative overflow-hidden">
<div class="absolute top-0 left-0 w-full h-1.5 bg-secondary-container"></div>
  <div class="text-center mb-10">
    <h2 class="font-headline text-2xl md:text-3xl text-primary font-semibold mb-2" data-text="join.heading">Elevate Your Career&mdash;Join Us Today</h2>
    <p class="font-body text-base text-on-surface-variant" data-text="join.subtitle">Apply for membership and unlock exclusive access to the network.</p>
  </div>
  <form id="join-form" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-1">
        <label class="font-label text-xs text-on-surface-variant uppercase" for="firstName">First Name</label>
        <input type="text" id="firstName" name="firstName" required
          class="w-full px-4 py-3 bg-white border border-outline-variant rounded focus:border-secondary-container focus:ring-1 focus:ring-secondary-container outline-none transition-all" />
      </div>
      <div class="space-y-1">
        <label class="font-label text-xs text-on-surface-variant uppercase" for="lastName">Last Name</label>
        <input type="text" id="lastName" name="lastName" required
          class="w-full px-4 py-3 bg-white border border-outline-variant rounded focus:border-secondary-container focus:ring-1 focus:ring-secondary-container outline-none transition-all" />
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-1">
        <label class="font-label text-xs text-on-surface-variant uppercase" for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone"
          class="w-full px-4 py-3 bg-white border border-outline-variant rounded focus:border-secondary-container focus:ring-1 focus:ring-secondary-container outline-none transition-all" />
      </div>
      <div class="space-y-1">
        <label class="font-label text-xs text-on-surface-variant uppercase" for="state">State</label>
        <select id="state" name="state" required
          class="w-full px-4 py-3 bg-white border border-outline-variant rounded focus:border-secondary-container focus:ring-1 focus:ring-secondary-container outline-none transition-all appearance-none">
          <option disabled selected value="">Select State</option>
          <option>NSW</option>
          <option>VIC</option>
          <option>QLD</option>
          <option>WA</option>
          <option>SA</option>
          <option>TAS</option>
          <option>ACT</option>
          <option>NT</option>
        </select>
      </div>
    </div>
    <div class="space-y-1">
      <label class="font-label text-xs text-on-surface-variant uppercase" for="organisation">Organisation</label>
      <input type="text" id="organisation" name="organisation"
        class="w-full px-4 py-3 bg-white border border-outline-variant rounded focus:border-secondary-container focus:ring-1 focus:ring-secondary-container outline-none transition-all" />
    </div>
    <div class="space-y-1">
      <label class="font-label text-xs text-on-surface-variant uppercase" for="jobTitle">Job Title</label>
      <input type="text" id="jobTitle" name="jobTitle"
        class="w-full px-4 py-3 bg-white border border-outline-variant rounded focus:border-secondary-container focus:ring-1 focus:ring-secondary-container outline-none transition-all" />
    </div>
    <button type="submit" id="join-submit" class="w-full bg-secondary-container text-on-secondary-container py-4 font-headline text-base font-semibold rounded-lg hover:shadow-lg transition-all mt-8" style="transition:all 0.2s" data-text="join.button">
      Submit Application
    </button>
    <p id="join-message" class="mt-4 text-sm text-center hidden"></p>
  </form>
</div>
</div>
</section>

<script>
  document.getElementById('join-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('join-submit');
    const msg = document.getElementById('join-message');
    if (!btn || !msg) return;
    btn.disabled = true;
    btn.textContent = 'Submitting...';
    msg.classList.add('hidden');

    const form = e.target;
    const data = new FormData(form);
    try {
      const res = await fetch('/api/join', {
        method: 'POST',
        body: JSON.stringify(Object.fromEntries(data)),
        headers: { 'Content-Type': 'application/json' }
      });
      const result = await res.json();
      if (res.ok) {
        msg.textContent = "Thanks! We'll be in touch.";
        msg.className = 'mt-4 text-sm text-center text-on-secondary-container';
        form.reset();
      } else {
        msg.textContent = result.error || 'Something went wrong. Please try again.';
        msg.className = 'mt-4 text-sm text-center';
        msg.style.color = '#ba1a1a';
      }
    } catch {
      msg.textContent = 'Network error. Please try again.';
      msg.className = 'mt-4 text-sm text-center';
      msg.style.color = '#ba1a1a';
    }
    msg.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Submit Application';
  });
</script>